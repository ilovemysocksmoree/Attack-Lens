# For LOCAL development only. Copy this file to .env (in the project root) and
# fill in your key. NEVER commit .env to git.
#
# For NETLIFY deployment, do NOT use this file. Instead set the variable in:
#   Netlify UI → Site settings → Environment variables → Add ANTHROPIC_API_KEY

ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional: change the local backend port (default 8787)
# ATTACKLENS_PORT=8787
